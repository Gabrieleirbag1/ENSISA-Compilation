package fr.uha.hassenforder.cage.turtle.direct.reader.ttl;


	import fr.uha.hassenforder.cage.turtle.direct.view.GraphicTurtle;
	import fr.uha.hassenforder.cage.turtle.direct.SymbolTable;


option mode=ACTION;

parser code {:

    private GraphicTurtle turtle;
    private SymbolTable table = null;

    public SymbolTable getTable () {
		if (table == null) table = new SymbolTable ();
		return table;
    }

    public GraphicTurtle getTurtle () {
		return turtle;
    }

    public void setTurtle (GraphicTurtle turtle) {
		this.turtle = turtle;
    }

:}

terminal Integer INTEGER;
terminal __REGEXP_1__;
terminal __REGEXP_2__;
terminal __REGEXP_3__;
terminal __REGEXP_4__;
terminal __REGEXP_5__;
terminal __REGEXP_6__;

nonterminal Commandes;
nonterminal Definition;
nonterminal Instruction;



start with Commandes;

Commandes	::=	Definition * 
			;

Definition	::=	Instruction:inst __REGEXP_1__ 
			;

Instruction	::=	{:    :} 
			|	__REGEXP_2__ INTEGER:v {:  parser.getTurtle().move(v);   :} 
			|	__REGEXP_3__ INTEGER:v {:  parser.getTurtle().move(v);   :} 
			|	__REGEXP_4__ INTEGER:x INTEGER:y {:  parser.getTurtle().go(x, y);   :} 
			|	__REGEXP_5__ {:  parser.getTurtle().up();   :} 
			|	__REGEXP_6__ {:  parser.getTurtle().down();   :} 
			;

